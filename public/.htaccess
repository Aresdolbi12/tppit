Options -Indexes
DirectoryIndex index.php

RewriteEngine On

# --- HTTPS-редирект: включить ПОСЛЕ установки сертификата в панели nic.ru ---
# RewriteCond %{HTTP:X-Forwarded-Proto} !https
# RewriteCond %{HTTPS} !on
# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# Всё, что не существующий файл — в роутер
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [L]

# Кэш статики
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 30 days"
    ExpiresByType application/javascript "access plus 30 days"
    ExpiresByType font/woff2 "access plus 365 days"
    ExpiresByType image/png "access plus 90 days"
    ExpiresByType image/gif "access plus 90 days"
    ExpiresByType image/svg+xml "access plus 90 days"
</IfModule>
